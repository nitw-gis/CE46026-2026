import polsartools as pst
import numpy as np
import rasterio

# Step 1: Load GSLC data (example HV polarization)
file_path = "HV.tif"

with rasterio.open(file_path) as src:
    hv = src.read(1)

print("Data loaded successfully")

# Step 2: Compute magnitude of complex data
magnitude = np.abs(hv)

print("Magnitude calculated")

# Step 3: Convert to backscatter (dB)
backscatter = 10 * np.log10(magnitude)

print("Backscatter calculated")

# Step 4: Save output raster
with rasterio.open(
    "backscatter_HV.tif",
    'w',
    driver='GTiff',
    height=backscatter.shape[0],
    width=backscatter.shape[1],
    count=1,
    dtype=backscatter.dtype
) as dst:
    dst.write(backscatter, 1)

print("Backscatter image saved")
