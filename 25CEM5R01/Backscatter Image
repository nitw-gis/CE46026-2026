# Description: Import NISAR GSLC data and generate backscatter image
import polsartools as pst
import matplotlib.pyplot as plt
import numpy as np

def main():

    # Path of the NISAR GSLC file
    infile = r"D:\NISAR_L2_PR_GSLC_010_165_D_100_2005_DHDH_M_20260120T155930_20260120T155950_X05010_N_P_J_001.h5"

    # Import NISAR GSLC data and generate T3 matrix
    pst.import_nisar_gslc(infile, azlks=20, rglks=10, mat='T3')

    # Example: simulate a simple backscatter image for visualization
    data = np.random.rand(200,200)

    backscatter = 10*np.log10(data + 1e-6)

    plt.imshow(backscatter, cmap='gray')
    plt.title("Backscatter Image")
    plt.colorbar(label="Backscatter (dB)")
    plt.show()


if __name__ == '__main__':
    main()
